	<application>

		<!-- ИМА ДОПЪЛНИТЕЛНА КОНФИГУРАЦИЯ В /IndexUIx/src/main/resources/META-INF/faces-config.xml
			КОЯТО СЕ НАСЛЕДЯВА ТУКА -->

		<locale-config>
			<default-locale>bg</default-locale>
			<supported-locale>en</supported-locale>
		</locale-config>

		<!-- Навигационните са общи и стоят в основния проект -->
		<resource-bundle>
			<base-name>i18n.navigation</base-name>
			<var>navTexts</var>
		</resource-bundle>
		<!-- и тези конкретните за системата -->
		<resource-bundle>
			<base-name>i18n.beanMessages</base-name>
			<var>beanMessages</var>
		</resource-bundle>
		<resource-bundle>
			<base-name>i18n.labels</base-name>
			<var>labels</var>
		</resource-bundle>

		<system-event-listener>
			<system-event-listener-class>com.ib.urireg.system.MySystemListener</system-event-listener-class>
			<system-event-class>jakarta.faces.event.PostConstructApplicationEvent</system-event-class>
		</system-event-listener>
		<system-event-listener>
			<system-event-listener-class>com.ib.urireg.system.MySystemListener</system-event-listener-class>
			<system-event-class>jakarta.faces.event.PreDestroyApplicationEvent</system-event-class>
		</system-event-listener>

	</application>

</faces-config>
